# ============================================================
# SFCK Plantation ERP — Demo Environment (TEMPLATE — safe to commit)
# ============================================================
# Copy this file to ".env.local" and fill in your real Neon values.
# Do NOT put real credentials in this file.
# ------------------------------------------------------------

# Pooled connection (PgBouncer). Use for normal app queries at runtime.
DATABASE_URL="postgresql://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require"

# Unpooled / direct connection. Use for migrations & schema changes.
DATABASE_URL_UNPOOLED="postgresql://<user>:<password>@<endpoint>.<region>.aws.neon.tech/<dbname>?sslmode=require"
